# Urban Energy backend — environment template. Copy to .env (never commit .env).
# In production these come from the host's secret manager, not a file.

# --- App ---
UE_ENV=dev                      # dev | staging | prod
UE_LOG_LEVEL=INFO
UE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Data source (Ports & Adapters) ---
# Which adapter feeds the dashboard. "seed" (dev) | "evoltsoft" (Phase 1) | "native" (later).
UE_DATA_SOURCE=seed

# --- Database ---
# Dev default = local SQLite (no install). Production = PostgreSQL.
# Example prod: postgresql+psycopg://user:pass@host:5432/urbanenergy
UE_DATABASE_URL=sqlite:///./urbanenergy.db

# --- Observability (optional; only inits when set) ---
UE_SENTRY_DSN=

# --- Security ---
UE_AUTH_MODE=dev                # dev (open, local only) | oauth (shared-auth)
# UE_JWT_SECRET, UE_GOOGLE_CLIENT_ID ... wired when AUTH_MODE=oauth

# --- Evoltsoft sync (Phase 1 — removable). Fill to go live, then UE_DATA_SOURCE=evoltsoft. ---
UE_EVOLTSOFT_BASE_URL=https://asia-south1-urbanenergy-prod.cloudfunctions.net
UE_EVOLTSOFT_FIREBASE_API_KEY=
UE_EVOLTSOFT_EMAIL=
UE_EVOLTSOFT_PASSWORD=
UE_EVOLTSOFT_BUSINESS_ORG_ID=
